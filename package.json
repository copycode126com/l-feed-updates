{
  "name": "l-feed-update",
  "version": "1.0.0",
  "description": "A markdown-powered changelog/update site generator",
  "type": "module",
  "scripts": {
    "dev": "node --watch scripts/generate-updates.mjs & npx vite dev",
    "build": "node scripts/generate-updates.mjs && npx vite build",
    "preview": "npx vite preview",
    "generate": "node scripts/generate-updates.mjs"
  },
  "devDependencies": {
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2",
    "vite": "^7.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
